def train_and_evaluate(model, label, batch_size=16):
    """Train a model and return history + metrics"""
    print(f"\n{'='*60}")
    print(f"  {label}")
    print(f"{'='*60}")

    # Reset seeds for fair comparison
    tf.random.set_seed(42)
    np.random.seed(42)

    model.compile(
        optimizer=Adam(learning_rate=0.0005),
        loss='categorical_crossentropy',
        metrics=['mae']
    )

    print(f"  Training (batch_size={batch_size})...")
    t0 = time.time()
    history = model.fit(
        X_train_s, y_train_seq,
        validation_data=(X_val_s, y_val_seq),
        epochs=500, batch_size=batch_size, verbose=0,
        callbacks=[
            EarlyStopping(monitor='val_loss', patience=40, restore_best_weights=True),
            ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=15, min_lr=1e-7, verbose=0)
        ]
    )
    elapsed = time.time() - t0

    y_pred = model.predict(X_test_s, verbose=0)

    total_epochs = len(history.history['loss'])
    best_epoch = np.argmin(history.history['val_loss']) + 1
    final_train_loss = history.history['loss'][-1]
    best_val_loss = min(history.history['val_loss'])
    gap = abs(final_train_loss - best_val_loss)

    print(f"  Done in {elapsed:.0f}s | {total_epochs} epochs | Best epoch: {best_epoch}")
    print(f"  Train loss: {final_train_loss:.4f} | Val loss: {best_val_loss:.4f} | Gap: {gap:.4f}")

    r2_scores = {}
    print(f"\n  Test performance:")
    for i, name in enumerate(target_names):
        actual = y_test_seq[:, :, i].flatten() * 1000
        predicted = y_pred[:, :, i].flatten() * 1000
        r2 = r2_score(actual, predicted)
        rmse = np.sqrt(mean_squared_error(actual, predicted))
        mae = mean_absolute_error(actual, predicted)
        r2_scores[name] = r2
        print(f"    {name}: R2={r2:.4f}, RMSE={rmse:.2f}, MAE={mae:.2f}")

    return {
        'label': label,
        'history': history,
        'y_pred': y_pred,
        'gap': gap,
        'train_loss': final_train_loss,
        'val_loss': best_val_loss,
        'best_epoch': best_epoch,
        'total_epochs': total_epochs,
        'r2_scores': r2_scores,
        'batch_size': batch_size,
    }

# ============================================================================
# OPTION 1: INCREASED DROPOUT + L2 REGULARIZATION
# ============================================================================
def build_option1():
    inputs = Input(shape=(n_timesteps, 8))
    x = GRU(128, return_sequences=True,
            kernel_regularizer=l2(1e-4),
            recurrent_regularizer=l2(1e-4))(inputs)
    x = BatchNormalization()(x)
    x = Dropout(0.4)(x)
    x = GRU(64, return_sequences=True,
            kernel_regularizer=l2(1e-4),
            recurrent_regularizer=l2(1e-4))(x)
    x = BatchNormalization()(x)
    x = Dropout(0.3)(x)
    x = TimeDistributed(Dense(32, activation='relu', kernel_regularizer=l2(1e-4)))(x)
    x = Dropout(0.3)(x)
    x = TimeDistributed(Dense(16, activation='relu', kernel_regularizer=l2(1e-4)))(x)
    x = Dropout(0.2)(x)
    outputs = TimeDistributed(Dense(3, activation='softmax'))(x)
    return Model(inputs=inputs, outputs=outputs)

# ============================================================================
# OPTION 2: INCREASED BATCH SIZE (16 -> 32)
# ============================================================================
def build_option2():
    inputs = Input(shape=(n_timesteps, 8))
    x = GRU(128, return_sequences=True)(inputs)
    x = BatchNormalization()(x)
    x = Dropout(0.3)(x)
    x = GRU(64, return_sequences=True)(x)
    x = BatchNormalization()(x)
    x = Dropout(0.2)(x)
    x = TimeDistributed(Dense(32, activation='relu'))(x)
    x = Dropout(0.2)(x)
    x = TimeDistributed(Dense(16, activation='relu'))(x)
    x = Dropout(0.1)(x)
    outputs = TimeDistributed(Dense(3, activation='softmax'))(x)
    return Model(inputs=inputs, outputs=outputs)

# ============================================================================
# OPTION 3: GAUSSIAN NOISE ON INPUTS
# ============================================================================
def build_option3():
    inputs = Input(shape=(n_timesteps, 8))
    x = GaussianNoise(0.05)(inputs)
    x = GRU(128, return_sequences=True)(x)
    x = BatchNormalization()(x)
    x = Dropout(0.3)(x)
    x = GRU(64, return_sequences=True)(x)
    x = BatchNormalization()(x)
    x = Dropout(0.2)(x)
    x = TimeDistributed(Dense(32, activation='relu'))(x)
    x = Dropout(0.2)(x)
    x = TimeDistributed(Dense(16, activation='relu'))(x)
    x = Dropout(0.1)(x)
    outputs = TimeDistributed(Dense(3, activation='softmax'))(x)
    return Model(inputs=inputs, outputs=outputs)

