def build_gru_model():
    inputs = Input(shape=(n_timesteps, 8))

    # GRU layers process the temporal sequence
    x = GRU(128, return_sequences=True)(inputs)
    x = BatchNormalization()(x)
    x = Dropout(0.3)(x)

    x = GRU(64, return_sequences=True)(x)
    x = BatchNormalization()(x)
    x = Dropout(0.2)(x)

    # Dense layers applied at each timestep
    x = TimeDistributed(Dense(32, activation='relu'))(x)
    x = Dropout(0.2)(x)

    x = TimeDistributed(Dense(16, activation='relu'))(x)
    x = Dropout(0.1)(x)

    # Softmax output at each timestep: always sums to 1.0
    outputs = TimeDistributed(Dense(3, activation='softmax'))(x)

    return Model(inputs=inputs, outputs=outputs)

