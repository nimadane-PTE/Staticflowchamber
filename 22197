        "        X_single[0, t_idx, :] = [Aq, Cheight, Wheight, Cr, Wr, PHr, Mq, t_val]\n",
        "\n",
        "    X_scaled = scaler.transform(X_single.reshape(-1, 8)).reshape(1, n_timesteps, 8)\n",
        "    preds = model.predict(X_scaled, verbose=0)[0]  # (11, 3)\n",
        "\n",
        "    # Take only t=0.1 to t=1.0 (skip t=0), convert to percentages\n",
        "    preds_eval = preds[EVAL_INDICES] * 100  # (10, 3)\n",
        "    return preds_eval[:, 0], preds_eval[:, 1], preds_eval[:, 2]  # danger%, detection%, below%\n",
        "\n",
        "\n",
        "def design_for_operator(Wr, Wheight, show_details=True):\n",
        "    if show_details:\n",
        "        print(f\"\\n   Designing for Wr={Wr:.3f} m, Wheight={Wheight:.3f} m ...\")\n",
        "        print(f\"   Conditions: Aq=1.0 m/s, Mq=0.15 kg/h\")\n",
        "\n",
        "    Aq_worst = 1.0\n",
        "    Mq_worst = 0.15\n",
        "\n",
        "    Cr_min = max(Wr + 0.05, df_unique['Cr'].quantile(0.05))\n",
        "    Cr_max = df_unique['Cr'].quantile(0.95)\n",
        "    Cheight_min = max(0.50, Wheight + 0.15)\n",
        "    Cheight_max = df_unique['Cheight'].quantile(0.95)\n",
        "    Alpha_min = 0.15\n",
        "    Alpha_max = 0.85\n",
        "    bounds = [(Cr_min, Cr_max), (Cheight_min, Cheight_max), (Alpha_min, Alpha_max)]\n",
        "\n",
        "    if show_details:\n",
        "        print(f\"   Cr=[{Cr_min:.3f},{Cr_max:.3f}], Cheight=[{Cheight_min:.3f},{Cheight_max:.3f}], Alpha=[{Alpha_min},{Alpha_max}]\")\n",
        "\n",
        "    # CONSERVATIVE\n",
        "    if show_details: print(\"   Optimizing CONSERVATIVE...\")\n",
        "    t0 = time.time()\n",
        "\n",
        "    def conservative_objective(params):\n",
        "        Cr, Cheight, Alpha = params\n",
        "        danger, detection, below = predict_all_times(\n",
        "            Aq_worst, Cheight, Wheight, Cr, Wr, Alpha, Mq_worst)\n",
        "        return np.sum(1000 * danger + -0.5 * detection + 1 * below)\n",
        "\n",
        "    result_cons = differential_evolution(\n",
        "        conservative_objective, bounds=bounds, strategy='best1bin',\n",
        "        maxiter=200, popsize=15, seed=42, polish=True)\n",
        "    Cr_c, Ch_c, Al_c = result_cons.x\n",
        "    if show_details: print(f\"   Done in {time.time()-t0:.0f}s\")\n",
        "\n",
        "    # DETECTION\n",
        "    if show_details: print(\"   Optimizing DETECTION-OPTIMIZED...\")\n",
        "    t0 = time.time()\n",
        "\n",
        "    def detection_objective(params):\n",
        "        Cr, Cheight, Alpha = params\n",
        "        danger, detection, below = predict_all_times(\n",
        "            Aq_worst, Cheight, Wheight, Cr, Wr, Alpha, Mq_worst)\n",
        "        return np.sum(50 * danger + -10 * detection + 1 * below)\n",
        "\n",
        "    result_det = differential_evolution(\n",
        "        detection_objective, bounds=bounds, strategy='best1bin',\n",
        "        maxiter=200, popsize=15, seed=43, polish=True)\n",
        "    Cr_d, Ch_d, Al_d = result_det.x\n",
        "    if show_details: print(f\"   Done in {time.time()-t0:.0f}s\")\n",
        "\n",
        "    # Get percentages\n",
        "    danger_c, detect_c, below_c = predict_all_times(\n",
        "        Aq_worst, Ch_c, Wheight, Cr_c, Wr, Al_c, Mq_worst)\n",
        "    danger_d, detect_d, below_d = predict_all_times(\n",
        "        Aq_worst, Ch_d, Wheight, Cr_d, Wr, Al_d, Mq_worst)\n",
        "\n",
        "    # Boundary warnings\n",
        "    warnings_list = []\n",
        "    for label, vals in [('Conservative', [Cr_c, Ch_c, Al_c]),\n",
        "                         ('Detection', [Cr_d, Ch_d, Al_d])]:\n",
        "        for name, val, (lo, hi) in zip(['Cr','Cheight','Alpha'], vals, bounds):\n",
        "            if abs(val - lo) < 0.005 or abs(val - hi) < 0.005:\n",
        "                warnings_list.append(f\"{label} {name}={val:.4f} at boundary [{lo:.3f}, {hi:.3f}]\")\n",
        "\n",
        "    if show_details:\n",
        "        if warnings_list:\n",
        "            for w in warnings_list: print(f\"   WARNING: {w}\")\n",
        "        print(\"   DESIGN COMPLETE\")\n",
        "\n",
        "    return {\n",
        "        'inputs': {'Wr': Wr, 'Wheight': Wheight, 'Aq': 1.0, 'Mq': 0.15},\n",
        "        'eval_times': EVAL_TIMES,\n",
        "        'warnings': warnings_list,\n",
        "        'conservative': {\n",
        "            'Cr': float(Cr_c), 'Cheight': float(Ch_c),\n",
        "            'PHr': float(Al_c * Cr_c), 'Alpha': float(Al_c),\n",
        "            'danger_by_time': [float(x) for x in danger_c],\n",
        "            'detection_by_time': [float(x) for x in detect_c],\n",
        "            'below_by_time': [float(x) for x in below_c],\n",
        "            'avg_danger': float(np.mean(danger_c)),\n",
        "            'avg_detection': float(np.mean(detect_c)),\n",
        "            'avg_below': float(np.mean(below_c)),\n",
        "        },\n",
        "        'detection_optimized': {\n",
        "            'Cr': float(Cr_d), 'Cheight': float(Ch_d),\n",
        "            'PHr': float(Al_d * Cr_d), 'Alpha': float(Al_d),\n",
        "            'danger_by_time': [float(x) for x in danger_d],\n",
        "            'detection_by_time': [float(x) for x in detect_d],\n",
        "            'below_by_time': [float(x) for x in below_d],\n",
        "            'avg_danger': float(np.mean(danger_d)),\n",
        "            'avg_detection': float(np.mean(detect_d)),\n",
        "            'avg_below': float(np.mean(below_d)),\n",
        "        }\n",
        "    }\n",
        "\n",
        "\n",
