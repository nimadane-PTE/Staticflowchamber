def predict_all_times(Aq, Cheight, Wheight, Cr, Wr, Alpha, Mq):
    """Single GRU forward pass for one parameter set across all 11 timesteps.
    Returns percentages for the 10 evaluation timesteps (skipping t=0)."""
    PHr = Alpha * Cr
    # Build full 11-step sequence
    X_single = np.zeros((1, n_timesteps, 8))
    for t_idx, t_val in enumerate(TIMESTEPS):
        X_single[0, t_idx, :] = [Aq, Cheight, Wheight, Cr, Wr, PHr, Mq, t_val]

    X_scaled = scaler.transform(X_single.reshape(-1, 8)).reshape(1, n_timesteps, 8)
    preds = model.predict(X_scaled, verbose=0)[0]  # (11, 3)

    # Take only t=0.1 to t=1.0 (skip t=0), convert to percentages
    preds_eval = preds[EVAL_INDICES] * 100  # (10, 3)
    return preds_eval[:, 0], preds_eval[:, 1], preds_eval[:, 2]  # danger%, detection%, below%


def design_for_operator(Wr, Wheight, show_details=True):
    if show_details:
        print(f"\n   Designing for Wr={Wr:.3f} m, Wheight={Wheight:.3f} m ...")
        print(f"   Conditions: Aq=1.0 m/s, Mq=0.15 kg/h")

    Aq_worst = 1.0
    Mq_worst = 0.15

    Cr_min = max(Wr + 0.05, df_unique['Cr'].quantile(0.05))
    Cr_max = df_unique['Cr'].quantile(0.95)
    Cheight_min = max(0.50, Wheight + 0.15)
    Cheight_max = df_unique['Cheight'].quantile(0.95)
    Alpha_min = 0.15
    Alpha_max = 0.85
    bounds = [(Cr_min, Cr_max), (Cheight_min, Cheight_max), (Alpha_min, Alpha_max)]

    if show_details:
        print(f"   Cr=[{Cr_min:.3f},{Cr_max:.3f}], Cheight=[{Cheight_min:.3f},{Cheight_max:.3f}], Alpha=[{Alpha_min},{Alpha_max}]")

    # CONSERVATIVE
    if show_details: print("   Optimizing CONSERVATIVE...")
    t0 = time.time()

    def conservative_objective(params):
        Cr, Cheight, Alpha = params
        danger, detection, below = predict_all_times(
            Aq_worst, Cheight, Wheight, Cr, Wr, Alpha, Mq_worst)
        return np.sum(1000 * danger + -0.5 * detection + 1 * below)

    result_cons = differential_evolution(
        conservative_objective, bounds=bounds, strategy='best1bin',
        maxiter=200, popsize=15, seed=42, polish=True)
    Cr_c, Ch_c, Al_c = result_cons.x
    if show_details: print(f"   Done in {time.time()-t0:.0f}s")

    # DETECTION
    if show_details: print("   Optimizing DETECTION-OPTIMIZED...")
    t0 = time.time()

    def detection_objective(params):
        Cr, Cheight, Alpha = params
        danger, detection, below = predict_all_times(
            Aq_worst, Cheight, Wheight, Cr, Wr, Alpha, Mq_worst)
        return np.sum(50 * danger + -10 * detection + 1 * below)

    result_det = differential_evolution(
        detection_objective, bounds=bounds, strategy='best1bin',
        maxiter=200, popsize=15, seed=43, polish=True)
    Cr_d, Ch_d, Al_d = result_det.x
    if show_details: print(f"   Done in {time.time()-t0:.0f}s")

    # Get percentages
    danger_c, detect_c, below_c = predict_all_times(
        Aq_worst, Ch_c, Wheight, Cr_c, Wr, Al_c, Mq_worst)
    danger_d, detect_d, below_d = predict_all_times(
        Aq_worst, Ch_d, Wheight, Cr_d, Wr, Al_d, Mq_worst)

    # Boundary warnings
    warnings_list = []
    for label, vals in [('Conservative', [Cr_c, Ch_c, Al_c]),
                         ('Detection', [Cr_d, Ch_d, Al_d])]:
        for name, val, (lo, hi) in zip(['Cr','Cheight','Alpha'], vals, bounds):
            if abs(val - lo) < 0.005 or abs(val - hi) < 0.005:
                warnings_list.append(f"{label} {name}={val:.4f} at boundary [{lo:.3f}, {hi:.3f}]")

    if show_details:
        if warnings_list:
            for w in warnings_list: print(f"   WARNING: {w}")
        print("   DESIGN COMPLETE")

    return {
        'inputs': {'Wr': Wr, 'Wheight': Wheight, 'Aq': 1.0, 'Mq': 0.15},
        'eval_times': EVAL_TIMES,
        'warnings': warnings_list,
        'conservative': {
            'Cr': float(Cr_c), 'Cheight': float(Ch_c),
            'PHr': float(Al_c * Cr_c), 'Alpha': float(Al_c),
            'danger_by_time': [float(x) for x in danger_c],
            'detection_by_time': [float(x) for x in detect_c],
            'below_by_time': [float(x) for x in below_c],
            'avg_danger': float(np.mean(danger_c)),
            'avg_detection': float(np.mean(detect_c)),
            'avg_below': float(np.mean(below_c)),
        },
        'detection_optimized': {
            'Cr': float(Cr_d), 'Cheight': float(Ch_d),
            'PHr': float(Al_d * Cr_d), 'Alpha': float(Al_d),
            'danger_by_time': [float(x) for x in danger_d],
            'detection_by_time': [float(x) for x in detect_d],
            'below_by_time': [float(x) for x in below_d],
            'avg_danger': float(np.mean(danger_d)),
            'avg_detection': float(np.mean(detect_d)),
            'avg_below': float(np.mean(below_d)),
        }
    }


